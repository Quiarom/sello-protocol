                {
                    "key": "usageType",
                    "type": "integer",
                    "required": false,
                    "array": false,
                    "default": null,
                    "min": -9223372036854775808,
                    "max": 9223372036854775807
                },
                {
                    "key": "timestamp",
                    "type": "string",
