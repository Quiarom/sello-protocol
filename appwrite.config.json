                {
                    "key": "walletAddress",
                    "type": "string",
                    "required": false,
                    "array": false,
                    "size": 64,
                    "default": null,
                    "encrypt": false
                },
                {
                    "key": "maxAutoPayPerTx",
                    "type": "double",
                    "required": false,
                    "array": false,
                    "default": null,
                    "min": -,
                    "max": 
                },
                {
                    "key": "maxAutoPayPerDay",
                    "type": "double",
                    "required": false,
                    "array": false,
                    "default": null,
                    "min": -,
                    "max": 
                }
            ],
            "indexes": []
        },
        {
            "$id": "usage-receipts",
            "$permissions": [],
            "databaseId": "sello-db",
            "name": "usage_receipts",
            "enabled": true,
            "rowSecurity": false,
            "columns": [
